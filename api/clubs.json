---
layout: null
---
[
  {% assign canonical_clubs = site.clubs | where: "language", "en" %}
  {% for club in canonical_clubs %}
  {
    "name": {{ club.name | jsonify }},
    "slug": {{ club.slug | jsonify }},
    "url": {{ club.url | relative_url | jsonify }},
    "country": {{ club.country | jsonify }},
    "days": {{ club.days | jsonify }},
    "time": {{ club.time | jsonify }},
    "frequency": {{ club.frequency | jsonify }},
    "location": {
      "name": {{ club.location.name | jsonify }},
      "address": {{ club.location.address | jsonify }},
      "lat": {{ club.location.lat }},
      "lng": {{ club.location.lng }}
    },
    "cost": {{ club.cost | jsonify }},
    "age_restriction": {{ club.age_restriction | jsonify }},
    "website": {{ club.website | jsonify }},
    "meetup": {{ club.meetup | jsonify }},
    "facebook": {{ club.facebook | jsonify }},
    "description": {{ club.description | markdownify | strip_html | normalize_whitespace | jsonify }},
    "image": {{ club.image | jsonify }},
    "type": {% if club.type %}{{ club.type | jsonify }}{% else %}["Board Games"]{% endif %}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
{% comment %}One entry per club. Site.clubs includes language clones at
/de/clubs/, /fr/clubs/ etc. emitted by _plugins/club_language_clones.rb —
we filter to the canonical English-URL version so the map shows each
club once. The frontend's localiseClubUrl() rewrites the URL to match
the visitor's language at click time.{% endcomment %}
